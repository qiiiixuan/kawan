name = "goodbois-worker"
main = "src/index.ts"
compatibility_date = "2026-05-09"

# Copy this file to wrangler.toml during Worker setup.
# Bindings are placeholders until the Cloudflare resources exist.

[[d1_databases]]
binding = "DB"
database_name = "goodbois"
database_id = "replace-with-d1-id"
migrations_dir = "migrations"

[[kv_namespaces]]
binding = "SESSION_KV"
id = "replace-with-kv-id"

[[r2_buckets]]
binding = "RECEIPTS"
bucket_name = "goodbois-receipts"

[ai]
binding = "AI"

[vars]
EXPORT_TOKEN = "dev"
WORKER_URL = "http://127.0.0.1:8787"
ONEMAP_API_BASE_URL = "https://www.onemap.gov.sg"
# Wheelchair mode tries OneMap BFA first, then falls back to public walking.
ONEMAP_WHEELCHAIR_ROUTE_TYPE = "walk"

# Configure secrets with Wrangler, never in this file:
# wrangler secret put ONEMAP_ACCESS_TOKEN
# or
# wrangler secret put ONEMAP_EMAIL
# wrangler secret put ONEMAP_PASSWORD
