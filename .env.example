# Next.js frontend
# When set, the kiosk POSTs /turn here and prompts for mic permission.
# When unset, the kiosk runs the offline mock-fixture demo flow.
NEXT_PUBLIC_KAWAN_API_BASE=http://127.0.0.1:8787

# Worker secrets are configured separately with Wrangler.
# Local dev: copy workers/.env.local to workers/.dev.vars (or just edit
# workers/.dev.vars directly) so wrangler can load SEALION_API_KEY.

# For OneMap live routing (NTH map render), keep credentials in Worker secrets:
#   cd workers
#   wrangler secret put ONEMAP_ACCESS_TOKEN
# or
#   wrangler secret put ONEMAP_EMAIL
#   wrangler secret put ONEMAP_PASSWORD
